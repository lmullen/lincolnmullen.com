{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Serve development version",
      "type": "shell",
      "command": "make preview",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": true,
        "clear": true
      },
      "group": "build",
      "problemMatcher": [ ]
    },
    {
      "label": "New post",
      "type": "shell",
      "command": "./new-post.sh",
      "args": [
        "${input:newPostTitle}"
      ],
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true,
        "close": true
      },
      "problemMatcher": [ ]
    },
    {
      "label": "New micro post",
      "type": "shell",
      "command": "./new-micro.sh",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": [ ]
    },
    {
      "label": "Clean up markdown",
      "type": "shell",
      "command": "tmpfile=$(mktemp) && pandoc \"${file}\" -t markdown --markdown-headings=atx --standalone --wrap=none -o \"$tmpfile\" && mv \"$tmpfile\" \"${file}\"",
      "options": {
        "shell": {
          "executable": "/bin/bash",
          "args": ["-c"]
        }
      },
      "presentation": {
        "echo": false,
        "reveal": "never",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true,
        "close": true
      },
      "problemMatcher": [ ]
    },
    {
      "label": "Copy permalink",
      "type": "shell",
      "command": "./permalink.sh",
      "args": [
        "${file}"
      ],
      "presentation": {
        "echo": false,
        "reveal": "never",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true,
        "close": true
      },
      "problemMatcher": [ ]
    }
  ],
  "inputs": [
    {
      "id": "newPostTitle",
      "type": "promptString",
      "description": "What is the the title for the new post?"
    }
  ]
}
